{
  "name": "AI-SPICY-CHAT-BOT",
  "description": "Free AI-powered Telegram chat bot using Groq API",
  "logo": "https://telegra.ph/file/2c6d1a6f78eba6199933a.jpg",
  "keywords": [
    "chatbot",
    "ai",
    "groq",
    "pyrogram",
    "telegram"
  ],
  "buildpacks": [
    {
      "url": "heroku/python"
    }
  ],
  "repository": "https://github.com/spicycodez/AI-SPICY-CHAT-BOT",
  "env": {
    "API_ID": {
      "description": "Your Telegram API ID from https://my.telegram.org",
      "required": true
    },
    "API_HASH": {
      "description": "Your Telegram API Hash from https://my.telegram.org",
      "required": true
    },
    "BOT_TOKEN": {
      "description": "Bot token from @BotFather",
      "required": true
    },
    "GROQ_API_KEY": {
      "description": "Free API key from https://console.groq.com",
      "required": true
    },
    "BOT_NAME": {
      "description": "Name of your bot",
      "required": false,
      "value": "Pari"
    },
    "MEMORY_LIMIT": {
      "description": "Number of previous messages to remember",
      "required": false,
      "value": "10"
    },
    "GROQ_MODEL": {
      "description": "Groq model to use",
      "required": false,
      "value": "mixtral-8x7b-32768"
    },
    "MONGO_URL": {
      "description": "MongoDB URL (optional)",
      "required": false
    },
    "START_IMG": {
      "description": "Image URL for /start command (optional)",
      "required": false
    }
  }
}
