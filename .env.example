# Telegram API credentials — https://my.telegram.org se lo (App banake)
API_ID=12345678
API_HASH=your_api_hash_here

# @BotFather se bana bot ka token
BOT_TOKEN=123456789:ABCDEF-your-bot-token

# Optional — Assistant/Userbot session string (generate_session.py chalake banao)
# Khali chhod do agar assistant nahi chahiye, sirf normal bot chalega
SESSION_STRING=

# Groq API key (FREE) — https://console.groq.com se lo
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=openai/gpt-oss-20b

# Bot/persona ka naam
BOT_NAME=Pari

# Optional — /start aur "thanks for adding me" panel ki banner image (URL)
# Khali chhod do agar image nahi chahiye, sirf text panel chalega
START_IMG=

# Kitne purane messages yaad rakhe context ke liye
MEMORY_LIMIT=10
